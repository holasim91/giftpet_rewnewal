# ──────────────────────────────────────────────────────
# GIFT PET — 환경변수 목록
# 이 파일을 복사하여 .env.local 을 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 .gitignore 에 포함되어 절대 커밋하지 마세요.
# ──────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────
# Supabase 콘솔 → Settings → API Keys 에서 확인
# 레거시 anon/service_role key는 2026년 말 지원 종료 예정.
# 새 키 형식: sb_publishable_xxx / sb_secret_xxx

# 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=

# Publishable Key (구 anon key 대체)
# 브라우저에 노출 가능 — RLS 정책으로 접근 범위 제한
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret Key (구 service_role key 대체)
# 서버 전용 — RLS 우회, 브라우저에 절대 노출 금지
# 브라우저에서 사용 시 HTTP 401 반환
SUPABASE_SECRET_KEY=

# ── Prisma / Database ─────────────────────────────────
# Supabase 콘솔 → Settings → Database → Connection string

# Transaction Pooler URL (런타임 쿼리, 포트 6543)
# 형식: postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Direct Connection URL (prisma migrate 전용, 포트 5432)
# 형식: postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=

# ── NextAuth.js v5 ───────────────────────────────────
# v5에서는 AUTH_SECRET 사용 (NEXTAUTH_SECRET도 하위 호환)
# openssl rand -base64 32
AUTH_SECRET=
