# ──────────────────────────────────────────────────────
# GIFT PET — 환경변수 목록
# 이 파일을 복사하여 .env.local 을 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 .gitignore 에 포함되어 절대 커밋하지 마세요.
# ──────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────
# Supabase 콘솔 → Project Settings → API 에서 확인

# 프로젝트 URL (브라우저에서도 사용하므로 NEXT_PUBLIC_ 접두사)
NEXT_PUBLIC_SUPABASE_URL=

# 익명 키 — 공개 키이므로 클라이언트 노출 허용
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서비스 롤 키 — 서버 전용, 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# ── Prisma / Database ─────────────────────────────────
# Supabase 콘솔 → Project Settings → Database → Connection string 에서 확인

# Transaction Pooler URL (런타임 쿼리용, 포트 6543)
# 형식: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Direct Connection URL (마이그레이션 전용, 포트 5432)
# 형식: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=

# ── NextAuth.js ───────────────────────────────────────
# 로컬 개발: http://localhost:3000
# 프로덕션: https://your-domain.vercel.app
NEXTAUTH_URL=

# openssl rand -base64 32 으로 생성한 임의 문자열
NEXTAUTH_SECRET=
